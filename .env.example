# 環境変数設定例

# ====================================
# JWT認証設定
# ====================================

# JWTトークンの署名に使用する秘密鍵（必須）
# 本番環境では必ず強力なランダム文字列に変更してください
GCSIM_JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ====================================
# データベース設定
# ====================================

# データベースファイルのパス（デフォルト: ./data/gcsim.db）
# GCSIM_DB_PATH=./data/gcsim.db

# データベースのデバッグモード（true/false、デフォルト: false）
# SQLログを出力する場合は true に設定
# GCSIM_DB_DEBUG=false

# ====================================
# 管理者ユーザー設定
# ====================================

# 初回起動時に作成される管理者ユーザーの設定
# これらの値は初回起動時のみ使用されます

# 管理者ユーザー名（デフォルト: admin）
GCSIM_ADMIN_USERNAME=admin

# 管理者パスワード（必須）
# 初回起動時に管理者アカウントに設定されるパスワード
GCSIM_ADMIN_PASSWORD=admin

# 管理者メールアドレス（デフォルト: admin@example.com）
GCSIM_ADMIN_EMAIL=admin@example.com

# ====================================
# CORS設定（オプション）
# ====================================

# 許可するオリジン（カンマ区切りで複数指定可能、デフォルト: *）
# 本番環境では必ず具体的なドメインを指定してください
# 例: GCSIM_CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com
GCSIM_CORS_ALLOWED_ORIGINS=*

# ====================================
# サーバー設定（オプション）
# ====================================

# 開発サーバーのポート番号（デフォルト: 8381）
# DEVSERVER_PORT=8381

# ====================================
# 設定方法
# ====================================
#
# 1. このファイルをコピーして `.env` という名前で保存
#    ```powershell
#    Copy-Item .env.example .env
#    ```
#
# 2. .env ファイルを編集して値を設定
#
# 3. PowerShellで環境変数を読み込み
#    ```powershell
#    Get-Content .env | ForEach-Object {
#        if ($_ -match '^([^#=]+)=(.+)$') {
#            $key = $matches[1].Trim()
#            $value = $matches[2].Trim()
#            [System.Environment]::SetEnvironmentVariable($key, $value, 'User')
#        }
#    }
#    ```
#
# 4. または、直接環境変数を設定
#    ```powershell
#    $env:GCSIM_JWT_SECRET = "your-secret-key"
#    $env:GCSIM_ADMIN_USERNAME = "admin"
#    $env:GCSIM_ADMIN_PASSWORD = "your-password"
#    $env:GCSIM_ADMIN_EMAIL = "admin@example.com"
#    ```
#
# ====================================
# セキュリティに関する注意事項
# ====================================
#
# - このファイルには機密情報が含まれるため、Gitにコミットしないでください
# - .gitignore に .env を追加することを推奨します
# - 本番環境では強力なパスワードとシークレットキーを使用してください
# - JWT_SECRETは最低32文字以上のランダムな文字列を推奨します
#
# 推奨される生成方法（PowerShell）:
# ```powershell
# # ランダムな64文字のシークレットキーを生成
# -join ((65..90) + (97..122) + (48..57) | Get-Random -Count 64 | ForEach-Object {[char]$_})
# ```
